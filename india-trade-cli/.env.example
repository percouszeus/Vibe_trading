# ── Zerodha Kite Connect ─────────────────────────────────────
# Get these from https://developers.kite.trade/
KITE_API_KEY=your_kite_api_key_here
KITE_API_SECRET=your_kite_api_secret_here

# ── Groww Partner API ────────────────────────────────────────
# Get these from Groww Partner portal
GROWW_CLIENT_ID=your_groww_client_id_here
GROWW_CLIENT_SECRET=your_groww_client_secret_here
GROWW_REDIRECT_URL=http://localhost:8765/groww/callback

# ─────────────────────────────────────────────────────────────
# AI PROVIDER SETTINGS
# Set AI_PROVIDER to one of:
#   anthropic           — Anthropic Claude API key
#   openai              — OpenAI GPT API key
#   gemini              — Google Gemini API key (Google AI Studio)
#   claude_subscription — Claude Pro/Max subscription via CLI (no key needed)
#   ollama              — Ollama locally-hosted models (free, no key needed)
#   openai_subscription — ChatGPT Plus/Team via session token (unofficial)
#   gemini_subscription — Vertex AI / Google Workspace (GCP project)
# ─────────────────────────────────────────────────────────────
AI_PROVIDER=anthropic

# Optional: override the default model for the chosen provider
# Anthropic:  claude-opus-4-5, claude-sonnet-4-5, claude-haiku-3-5
# OpenAI:     gpt-4o, gpt-4o-mini, gpt-4-turbo
# Gemini:     gemini-2.5-pro, gemini-2.0-flash, gemini-1.5-pro
# AI_MODEL=claude-opus-4-5

# ── Anthropic / Claude ───────────────────────────────────────
# API key from https://console.anthropic.com/
# Works for: personal API, Claude Max (Max includes API quota)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ── OpenAI / GPT ─────────────────────────────────────────────
# API key from https://platform.openai.com/
# Note: ChatGPT Plus subscription ≠ API credits (billed separately)
OPENAI_API_KEY=your_openai_api_key_here

# ── Google Gemini / AI Studio ─────────────────────────────────
# Free API key from https://aistudio.google.com/
# Supports Gemini 2.5 Pro, 2.0 Flash, 1.5 Pro, etc.
GEMINI_API_KEY=your_gemini_api_key_here

# ── OpenAI Subscription (ChatGPT Plus/Team) ───────────────────
# For users with ChatGPT subscription but no API key.
# Get from: chatgpt.com → DevTools → Application → Cookies
# Cookie name: __Secure-next-auth.session-token
# ⚠️  Unofficial — may break; for personal/dev use only.
# OPENAI_SESSION_TOKEN=your_session_token_here

# ── Google Gemini Subscription (Vertex AI / Workspace) ────────
# For Google Workspace Business/Enterprise or GCP customers.
# Requires: gcloud auth application-default login
# And Vertex AI API enabled in your GCP project.
# GOOGLE_CLOUD_PROJECT=your-gcp-project-id
# GOOGLE_CLOUD_LOCATION=us-central1

# ── Fyers Broker (recommended, free) ────────────────────────
# Get from https://myapi.fyers.in
# FYERS_APP_ID=XXXX-100
# FYERS_SECRET_KEY=your_secret_here
FYERS_REDIRECT_URL=http://127.0.0.1:8765/fyers/callback

# ── Angel One SmartAPI (free) ────────────────────────────────
# ANGEL_API_KEY=your_api_key_here
# ANGEL_CLIENT_CODE=your_login_id
# ANGEL_PASSWORD=your_password
# ANGEL_TOTP_SECRET=your_totp_seed

# ── Upstox (free) ───────────────────────────────────────────
# UPSTOX_API_KEY=your_api_key
# UPSTOX_API_SECRET=your_secret
# UPSTOX_REDIRECT_URL=http://127.0.0.1:8765/upstox/callback

# ── NewsAPI ──────────────────────────────────────────────────
# Free tier: 100 req/day — https://newsapi.org/
# NEWSAPI_KEY=your_newsapi_key_here
NEWSAPI_ENABLED=1

# ── Ollama / Local LLM (optional) ───────────────────────────
# Run any model locally for free: brew install ollama && ollama pull llama3.1
# AI_PROVIDER=ollama
# OLLAMA_MODEL=llama3.1
# OLLAMA_BASE_URL=http://localhost:11434/v1

# ── Custom OpenAI-compatible endpoint (optional) ────────────
# Works with: OpenRouter, PaleDotBlue, Groq, Together AI, LM Studio, vLLM, etc.
# AI_PROVIDER=openai
# OPENAI_BASE_URL=https://openrouter.ai/api/v1
# OPENAI_API_KEY=sk-or-v1-...
# OPENAI_MODEL=anthropic/claude-sonnet-4     # model name depends on your provider

# ── Telegram Bot (optional) ─────────────────────────────────
# Create via @BotFather on Telegram
# TELEGRAM_BOT_TOKEN=your_bot_token_here

# ── Platform Settings ────────────────────────────────────────
# PAPER or LIVE
TRADING_MODE=PAPER

# Default risk per trade as % of capital (e.g. 2 = 2%)
DEFAULT_RISK_PCT=2

# Your total trading capital in INR
TOTAL_CAPITAL=200000

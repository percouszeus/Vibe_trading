# ==============================================================================
# VIBE TRADING INDIA — OCI DEPLOYMENT CONFIGURATION
# ==============================================================================
# LLM Priority: NIM (cloud, 70B) → OpenRouter (cloud) → Ollama (local)
# Broker: Zerodha Kite Connect
# Mode: PAPER (never change without full review)
# ==============================================================================

# ── Trading Mode ─────────────────────────────────────────────
TRADING_MODE=PAPER
TOTAL_CAPITAL=1000000
DEFAULT_RISK_PCT=2

# ── LLM: Primary (NVIDIA NIM — cloud, 70B model) ────────────
# Sign up at https://build.nvidia.com — 5000 free credits
NIM_API_KEY=
NIM_API_KEY=
NIM_BASE_URL=https://integrate.api.nvidia.com/v1
NIM_MODEL=openai/gpt-oss-120b

# ── LLM: Fallback 1 (OpenRouter — cloud, multiple models) ───
# Sign up at https://openrouter.ai — free tier available
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# deepseek/deepseek-r1: free tier, 164k ctx, strong reasoning — best for trade analysis failover
# Other good options (if r1 quota exhausted):
#   google/gemini-2.5-flash-preview-05-20  (fast, 1M ctx)
#   meta-llama/llama-4-maverick            (free, 1M ctx)
#   deepseek/deepseek-chat-v3-0324:free    (fast free tier)
OPENROUTER_MODEL=deepseek/deepseek-r1

# ── LLM: Fallback 2 (Ollama — local, if installed) ──────────
LANGCHAIN_PROVIDER=ollama
LANGCHAIN_MODEL_NAME=llama3.1:8b
OLLAMA_BASE_URL=http://localhost:11434/v1
LANGCHAIN_TEMPERATURE=0.0
TIMEOUT_SECONDS=120
MAX_RETRIES=2

# ── LLM: For india-trade-cli compatibility ──────────────────
# These are auto-resolved by the orchestrator's get_active_llm_config()
# If running india-trade-cli standalone, set these manually:
AI_PROVIDER=openai
AI_PROVIDER=openai
OPENAI_BASE_URL=https://integrate.api.nvidia.com/v1
OPENAI_API_KEY=
AI_MODEL=openai/gpt-oss-120b

# ── Zerodha Kite Connect ─────────────────────────────────────
# Get from https://developers.kite.trade/
KITE_API_KEY=
KITE_API_SECRET=
KITE_MCP_URL=https://mcp.kite.trade/mcp

# ── Market Data ─────────────────────────────────────────────
MARKET_DATA_PROVIDER=kite
YFINANCE_FALLBACK=true

# ── Telegram Alerts (optional) ──────────────────────────────
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=
TELEGRAM_DAILY_REPORT=true
TELEGRAM_TRADE_ALERTS=true
TELEGRAM_RISK_ALERTS=true

# ── Orchestrator Settings ────────────────────────────────────
STOCK_UNIVERSE=NIFTY50
MAX_DAILY_ANALYSES=5
BACKTEST_LOOKBACK_DAYS=90
IMPROVEMENT_THRESHOLD=1.05
HEALTH_CHECK_INTERVAL=5

# ── Capital Management (50/25/25 Profit Split) ──────────────
INITIAL_CAPITAL=1000000
REINVEST_PCT=50
AI_FUND_PCT=25
OWNER_PCT=25
MAX_DRAWDOWN_PCT=15
MIN_TRADE_CAPITAL=50000
AI_AUTO_APPROVE_LIMIT=500

# ── Live Trading Graduation ─────────────────────────────────
GRAD_MIN_TRADING_DAYS=60
GRAD_MIN_WIN_RATE=0.50
GRAD_MIN_SHARPE=1.0
GRAD_MAX_DRAWDOWN=10
GRAD_MIN_PROFIT_FACTOR=1.5
DAILY_LOSS_LIMIT_PCT=0.03
WEEKLY_LOSS_LIMIT_PCT=0.05
EMERGENCY_STOP_DRAWDOWN=0.15

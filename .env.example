# ── Vibe Trading India — Environment Template ───────────────
# Copy this file to .env and fill in your API keys:
#   cp .env.example .env
#
# NEVER commit .env to git — it contains secrets.
# ==============================================================================

# ── Trading Mode (PAPER enforced — do NOT change) ───────────
TRADING_MODE=PAPER
TOTAL_CAPITAL=1000000
DEFAULT_RISK_PCT=2

# ── LLM: Primary (Ollama self-hosted) ───────────────────────
LANGCHAIN_PROVIDER=ollama
LANGCHAIN_MODEL_NAME=llama3.1:8b
OLLAMA_BASE_URL=http://localhost:11434/v1
LANGCHAIN_TEMPERATURE=0.0
TIMEOUT_SECONDS=120
MAX_RETRIES=2

# ── LLM: Fallback 1 (OpenRouter — sign up at openrouter.ai)
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=deepseek/deepseek-v3.2

# ── LLM: Fallback 2 (NVIDIA NIM — sign up at build.nvidia.com)
NIM_API_KEY=
NIM_BASE_URL=https://integrate.api.nvidia.com/v1
NIM_MODEL=meta/llama-3.1-70b-instruct

# ── Zerodha Kite Connect (https://developers.kite.trade/) ──
KITE_API_KEY=
KITE_API_SECRET=
KITE_MCP_URL=https://mcp.kite.trade/mcp

# ── Fyers (free market data — https://myapi.fyers.in) ──────
# FYERS_APP_ID=
# FYERS_SECRET_KEY=
FYERS_REDIRECT_URL=http://127.0.0.1:8765/fyers/callback

# ── Telegram Alerts (optional — create bot via @BotFather) ──
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=

# ── Orchestrator ────────────────────────────────────────────
STOCK_UNIVERSE=NIFTY50
MAX_DAILY_ANALYSES=5
BACKTEST_LOOKBACK_DAYS=90
IMPROVEMENT_THRESHOLD=1.05
HEALTH_CHECK_INTERVAL=5
